# ---- LLM ----
# Anthropic é o default; para usar OpenAI, troque langchain-anthropic por langchain-openai
ANTHROPIC_API_KEY=misa-onboarding-api-key
LLM_MODEL=claude-haiku-4-5
LLM_TEMPERATURE=0.0

# ---- MLflow ----
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=datathon-fase05

# ---- Qdrant ----
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=kb_atendimento

# ---- Langfuse (valores de dev, batem com docker-compose.yml) ----
LANGFUSE_PUBLIC_KEY=pk-lf-datathon-public
LANGFUSE_SECRET_KEY=sk-lf-datathon-secret
LANGFUSE_HOST=http://localhost:3000

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ---- Embedding ----
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
